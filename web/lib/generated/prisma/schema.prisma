generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id
  name              String
  email             String             @unique
  emailVerified     Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  streakGoalDays    Int?               @default(21)
  privateAccount    Boolean            @default(false)
  username          String?            @unique
  focusArea         String?
  bio               String?
  location          String?
  bannerColor       String?            @default("#e2e8f0")
  accounts          Account[]
  collections       Collection[]
  habits            Habit[]
  notification_read NotificationRead[]
  postHabits        PostHabit[]
  postHabitVotes    PostHabitVote[]
  routines          Routine[]
  sessions          Session[]
  todos             Todo[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Todo {
  id              String           @id @default(uuid())
  title           String
  description     String?
  category        String?
  priority        TodoPriority     @default(MEDIUM)
  status          TodoStatus       @default(PLANNED)
  dueAt           DateTime?
  scheduledTime   String? // store time as HH:mm string
  durationMinutes Int?
  location        String?
  reminder        String?
  recurrence      String?
  tags            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          String
  iconColor       String           @default("#E5E7EB")
  iconName        String           @default("Notebook")
  archived        Boolean          @default(false)
  collections     CollectionTodo[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId, dueAt])
  @@map("todo")
}

model Collection {
  id          String           @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionTodo[]

  @@index([userId, name])
  @@map("collection")
}

model CollectionTodo {
  id           String     @id @default(uuid())
  collectionId String
  todoId       String
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  todo         Todo       @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@unique([collectionId, todoId], name: "collectionId_todoId")
  @@map("collection_todo")
}

model Habit {
  id                   String               @id @default(uuid())
  name                 String
  description          String?
  cadence              String
  startDate            DateTime
  timeWindow           String?
  goalAmount           Float                @default(1)
  goalUnit             String               @default("count")
  goalUnitCategory     String               @default("Quantity")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @default(now()) @updatedAt
  userId               String
  sourcePopularPostId  String?
  dailyProgress        Float                @default(0)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyProgressEntries HabitDailyProgress[]
  post_habit           PostHabit[]
  routineHabits        RoutineHabit[]

  @@unique([id, userId])
  @@unique([userId, sourcePopularPostId])
  @@index([userId])
  @@map("habit")
}

model HabitDailyProgress {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime
  progress  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
  @@map("habit_daily_progress")
}

model Routine {
  id         String            @id @default(uuid())
  name       String
  anchor     String?
  notes      String?
  timeWindow RoutineTimeWindow @default(Anytime)
  isDefault  Boolean           @default(false)
  userId     String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @default(now()) @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits     RoutineHabit[]

  @@index([userId])
  @@map("routine")
}

model RoutineHabit {
  id        String   @id @default(uuid())
  routineId String
  habitId   String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([routineId, habitId])
  @@index([routineId])
  @@index([habitId])
  @@map("routine_habit")
}

model PostHabit {
  id          String          @id @default(uuid())
  title       String
  description String?
  cadence     String
  category    HabitCategory
  habitId     String
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  votesCount  Int             @default(0)
  habit       Habit           @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       PostHabitVote[]

  @@index([userId])
  @@index([habitId])
  @@map("post_habit")
}

model PostHabitVote {
  id          String    @id @default(uuid())
  postHabitId String
  userId      String
  createdAt   DateTime  @default(now())
  postHabit   PostHabit @relation(fields: [postHabitId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postHabitId, userId], name: "postHabitId_userId")
  @@index([postHabitId])
  @@index([userId])
  @@map("post_habit_vote")
}

model NotificationRead {
  id             String   @id
  userId         String
  notificationId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TodoStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum HabitCategory {
  Movement
  Energy
  Focus
  Recovery
  Mindset
  Health
}

enum RoutineTimeWindow {
  Anytime
  Morning
  Workday
  Evening
}
